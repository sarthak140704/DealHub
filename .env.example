# PostgreSQL connection string used by Prisma (see prisma.config.ts / prisma/schema.prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/dealhub?schema=public"

# Secret used to sign session JWTs (src/lib/auth.ts).
# REQUIRED in production — the app throws on startup if this is unset when NODE_ENV=production.
# Generate a strong value, e.g.: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"
